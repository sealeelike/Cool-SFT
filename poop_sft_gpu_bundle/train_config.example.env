# Optional defaults for run_train_job.sh
# Copy this file to: <workspace>/train_config.env
# Default workspace: sibling ./poopworkspace (or custom via --workspace-dir / POOPTRAIN_WORKSPACE_DIR)
# You can also point to a different file with:
#   export POOPTRAIN_CONFIG_FILE=/path/to/your.env

# POOPTRAIN_WORKSPACE_DIR=poopworkspace
# POOPTRAIN_MODEL_NAME=Qwen/Qwen2.5-0.5B
# POOPTRAIN_GCS_PREFIX=gs://your-bucket/exports/run-001
# POOPTRAIN_RESUME_MODE=auto
# POOPTRAIN_NUM_TRAIN_EPOCHS=3
# POOPTRAIN_MAX_STEPS=
# POOPTRAIN_SYNC_EVERY_STEPS=50
# POOPTRAIN_DATA_MODE=all
# POOPTRAIN_VAL_SIZE=0.1
# POOPTRAIN_SEED=42
# POOPTRAIN_CUTOFF_LEN=256
# POOPTRAIN_LEARNING_RATE=8e-5
# POOPTRAIN_BATCH_SIZE=1
# POOPTRAIN_GRAD_ACC=4
# POOPTRAIN_SAVE_STEPS=50
# POOPTRAIN_EVAL_STEPS=50
